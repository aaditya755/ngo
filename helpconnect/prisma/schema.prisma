generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("VOLUNTEER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  volunteer     Volunteer?
  ngoProfile    NGOProfile?
  chatMessages  ChatMessage[]
  notifications Notification[]
  onboarding    OnboardingProgress?
  posts         Post[]
  donations     Donation[]
  emergencies   ZoneEmergency[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Volunteer {
  id           String   @id @default(cuid())
  userId       String   @unique
  skills       String   @default("[]")
  location     String?
  zone         String?
  availability String?
  totalHours   Int      @default(0)
  totalPoints  Int      @default(0)
  wellnessFlag Boolean  @default(false)
  currentLat   Float?
  currentLng   Float?
  createdAt    DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments  Assignment[]
  hoursLogs    HoursLog[]
  shiftSignups ShiftSignup[]
  points       VolunteerPoints[]
  badges       BadgeEarned[]
}

model NGOProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  orgName        String
  description    String?
  specialization String   @default("[]")
  coverageZones  String   @default("[]")
  verified       Boolean  @default(false)
  logoUrl        String?
  website        String?
  createdAt      DateTime @default(now())

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  needs          CommunityNeed[]
  campaigns      Campaign[]
  events         Event[]
  posts          Post[]
  collaborations NeedCollaboration[]
}

model CommunityNeed {
  id              String   @id @default(cuid())
  title           String
  description     String
  zone            String
  lat             Float?
  lng             Float?
  category        String   @default("HEALTHCARE")
  severity        String   @default("MEDIUM")
  urgencyScore    Int      @default(50)
  status          String   @default("OPEN")
  ngoId           String
  isCollaborative Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ngo            NGOProfile        @relation(fields: [ngoId], references: [id])
  assignments    Assignment[]
  campaigns      Campaign[]
  collaborations NeedCollaboration[]
}

model Assignment {
  id          String   @id @default(cuid())
  volunteerId String
  needId      String
  role        String?
  matchScore  Float    @default(0)
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  volunteer   Volunteer     @relation(fields: [volunteerId], references: [id])
  need        CommunityNeed @relation(fields: [needId], references: [id])
  hoursLogs   HoursLog[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String    @id @default(cuid())
  ngoId        String
  needId       String?
  title        String
  description  String?
  targetAmount Float
  raisedAmount Float     @default(0)
  endDate      DateTime?
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())

  ngo          NGOProfile     @relation(fields: [ngoId], references: [id])
  need         CommunityNeed? @relation(fields: [needId], references: [id])
  donations    Donation[]
}

model Donation {
  id            String   @id @default(cuid())
  campaignId    String
  donorId       String
  amount        Float
  currency      String   @default("INR")
  status        String   @default("PENDING")
  transactionId String?
  createdAt     DateTime @default(now())

  campaign      Campaign @relation(fields: [campaignId], references: [id])
  donor         User     @relation(fields: [donorId], references: [id])
}

model HoursLog {
  id           String    @id @default(cuid())
  volunteerId  String
  assignmentId String?
  date         DateTime
  hours        Float
  checkIn      DateTime?
  checkOut     DateTime?
  notes        String?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())

  volunteer    Volunteer   @relation(fields: [volunteerId], references: [id])
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  ngoId       String
  title       String
  description String?
  date        DateTime
  location    String?
  lat         Float?
  lng         Float?
  capacity    Int      @default(50)
  qrCode      String?
  createdAt   DateTime @default(now())

  ngo         NGOProfile    @relation(fields: [ngoId], references: [id])
  signups     ShiftSignup[]
}

model ShiftSignup {
  id          String   @id @default(cuid())
  eventId     String
  volunteerId String
  checkedIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  event       Event     @relation(fields: [eventId], references: [id])
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@unique([eventId, volunteerId])
}

model VolunteerPoints {
  id          String   @id @default(cuid())
  volunteerId String
  points      Int
  reason      String
  createdAt   DateTime @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  emoji       String
  description String
  threshold   Int
  earned      BadgeEarned[]
}

model BadgeEarned {
  id          String   @id @default(cuid())
  volunteerId String
  badgeId     String
  earnedAt    DateTime @default(now())

  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  badge       Badge     @relation(fields: [badgeId], references: [id])

  @@unique([volunteerId, badgeId])
}

model Post {
  id          String    @id @default(cuid())
  ngoId       String
  authorId    String
  title       String
  slug        String    @unique
  content     String
  imageUrl    String?
  tags        String    @default("[]")
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  ngo         NGOProfile @relation(fields: [ngoId], references: [id])
  author      User       @relation(fields: [authorId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ZoneEmergency {
  id         String   @id @default(cuid())
  zone       String
  declaredBy String
  message    String
  active     Boolean  @default(true)
  alertType  String   @default("GENERAL")
  createdAt  DateTime @default(now())
  declarer   User     @relation(fields: [declaredBy], references: [id])
}

model NeedCollaboration {
  id       String   @id @default(cuid())
  needId   String
  ngoId    String
  status   String   @default("ACTIVE")
  joinedAt DateTime @default(now())

  need     CommunityNeed @relation(fields: [needId], references: [id])
  ngo      NGOProfile    @relation(fields: [ngoId], references: [id])

  @@unique([needId, ngoId])
}

model OnboardingProgress {
  id          String    @id @default(cuid())
  userId      String    @unique
  currentStep Int       @default(1)
  completedAt DateTime?
  data        String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
